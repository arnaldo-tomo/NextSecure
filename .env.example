# ============================================
# NextSecure — Environment Variables
# ============================================

# Database (Prisma)
# PostgreSQL: postgresql://user:password@localhost:5432/nextsecure
# MySQL:      mysql://user:password@localhost:3306/nextsecure
# SQLite:     file:./dev.db
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (SMTP) for password reset & email verification
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@nextsecure.dev"

# App
APP_NAME="NextSecure"
APP_URL="http://localhost:3000"
